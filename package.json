{
  "name": "github-copilot-receipt-generator",
  "version": "1.0.0",
  "description": "Generate quirky, shareable receipts for your GitHub Copilot usage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hkaanturgut/github-copilot-receipt-generator.git"
  },
